# Database
# DATABASE_URL uses the Docker-internal hostname "postgres" (for backend/worker containers).
DATABASE_URL=postgresql://visquery:changeme@postgres:5432/visquery
# SCRAPER_DATABASE_URL uses localhost because the scraper runs on the host, not in Docker.
# Postgres is port-mapped 5432:5432 so this works while docker-compose is up.
SCRAPER_DATABASE_URL=postgresql://visquery:changeme@localhost:5432/visquery
POSTGRES_USER=visquery
POSTGRES_PASSWORD=changeme
POSTGRES_DB=visquery

# Redis / RQ
REDIS_URL=redis://redis:6379/0

# Object Storage (S3-compatible: Supabase Storage or Backblaze B2)
OBJECT_STORAGE_URL=https://s3.us-east-005.backblazeb2.com
OBJECT_STORAGE_BUCKET=visquery-images
OBJECT_STORAGE_KEY_ID=your-key-id
OBJECT_STORAGE_APPLICATION_KEY=your-application-key

# CLIP & style model checkpoints
# Leave CLIP_CHECKPOINT_PATH empty to use the base open_clip ViT-B/32 weights.
# After LoRA fine-tuning, point this to the merged checkpoint.
CLIP_CHECKPOINT_PATH=
STYLE_CHECKPOINT_PATH=

# Reranker
RERANKER_MODEL=BAAI/bge-reranker-base

# LLM provider: "anthropic" or "ollama"
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# FAISS indexes
FAISS_DATA_DIR=/data/faiss
EMBEDDING_VERSION=base

# Retrieval defaults
MMR_LAMBDA=0.7
FUSION_METHOD=rrf
TOP_K_RETRIEVE=100
TOP_K_FINAL=30

# Logging
LOG_LEVEL=INFO

# Caddy / TLS
# Set this to your real domain for auto-HTTPS via Let's Encrypt.
# Use "localhost" for local dev (self-signed).
DOMAIN=localhost
