# Database
# DATABASE_URL uses Docker-internal hostname "postgres" (for backend/worker containers).
# SCRAPER_DATABASE_URL uses localhost because the scraper runs on the host, not in Docker.
DATABASE_URL=postgresql://visquery:changeme@postgres:5432/visquery
SCRAPER_DATABASE_URL=postgresql://visquery:changeme@localhost:5432/visquery
POSTGRES_USER=visquery
POSTGRES_PASSWORD=changeme
POSTGRES_DB=visquery

# Redis / RQ
REDIS_URL=redis://redis:6379/0

# Docker Compose env/layout
DOCKER_ENV_FILE=.env
STORAGE_ROOT=./storage
POSTGRES_DATA_PATH=./storage/postgres

# Object Storage (S3-compatible: Backblaze B2 or similar)
OBJECT_STORAGE_URL=https://s3.us-east-005.backblazeb2.com
OBJECT_STORAGE_BUCKET=visquery-images
OBJECT_STORAGE_KEY_ID=your-key-id
OBJECT_STORAGE_APPLICATION_KEY=your-application-key

# CLIP & style model checkpoints
# Leave CLIP_CHECKPOINT_PATH empty to use base open_clip ViT-B/32 weights.
# Set to /data/checkpoints/best_clip_model.pt when using fine-tuned model.
CLIP_CHECKPOINT_PATH=/data/checkpoints/best_clip_v2.pt
STYLE_CHECKPOINT_PATH=

# Reranker
RERANKER_MODEL=BAAI/bge-reranker-base

# LLM — Ollama Cloud (https://ollama.com)
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_VLM_MODEL=qwen3-vl:235b-cloud
RAG_LLM_MODEL=gemma4:31b-cloud
OLLAMA_MODEL=gemma4:31b-cloud

# Data directories (single volume mounted at /data in Docker)
FAISS_DATA_DIR=/data/vectors
EMBEDDING_VERSION=2

# Retrieval defaults
MMR_LAMBDA=0.7
FUSION_METHOD=rrf
TOP_K_RETRIEVE=100
TOP_K_FINAL=30

# Logging
LOG_LEVEL=INFO

# Caddy / TLS
# Set to your real domain for auto-HTTPS via Let's Encrypt.
# Use "localhost" for local dev (self-signed).
DOMAIN=localhost
